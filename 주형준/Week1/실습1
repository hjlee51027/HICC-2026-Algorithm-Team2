N = int(input())
people = []
rank = [1] * N

for _ in range(N):
    weightheight = list(map(int, input().split()))
    people.append(weightheight)

for i in range(N):
    for j in range(N):
        if i == j:
            continue
        else:
            if (people[i][0] < people[j][0]) and (people[i][1] < people[j][1]):
                rank[i] = rank[i] + 1

print(*rank)
