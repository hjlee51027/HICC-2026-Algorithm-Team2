n = int(input())
heights = list(map(int, input().split()))

stack = []
result = []

for i in range(n):
    current_h = heights[i] 
    
    while stack:
        if stack[-1][1] > current_h:
            result.append(stack[-1][0] + 1) 
            break
        else:
            stack.pop()
            
    if not stack:
        result.append(0)
        
    stack.append((i, current_h))

print(*(result))
